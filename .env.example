NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-side (for cron / admin jobs)
SUPABASE_SERVICE_ROLE_KEY=

# 后台用户管理入口（/admin/users）的固定账号密码
# 通过浏览器原生 HTTP Basic Auth 弹窗输入
# 未配置时 /admin/* 与 /api/admin/* 一律返回 503
ADMIN_USER=
ADMIN_PASS=

# 数据库 Postgres 直连串（应用运行时默认值）
# Supabase 控制台 → Project Settings → Database → Connection string（URI / Session pooler）
DATABASE_URL=

# 数据库导出源库连接串（用于 scripts/db-export-full.sh / db-export-incremental.sh）
# 迁移到自托管后，DATABASE_URL 可能指向目标库；导出补丁必须继续使用源库。
DB_EXPORT_DATABASE_URL=

# Cron security (for nightly refresh)
KNOWLEDGE_CRON_SECRET=
SMART_TOPICS_REFRESH_URL=

# AI Services - Primary OpenAI-compatible API
OPENAI_API_KEY=your_openai_api_key
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Knowledge Smart Topics (P1)
# Embeddings provider (must support /embeddings endpoint)
KNOWLEDGE_EMBEDDING_API_KEY=
KNOWLEDGE_EMBEDDING_BASE_URL=https://api.openai.com/v1
KNOWLEDGE_EMBEDDING_MODEL=text-embedding-3-small

# Topic naming provider (can be same as OPENAI_*)
KNOWLEDGE_TOPIC_NAMING_API_KEY=
KNOWLEDGE_TOPIC_NAMING_BASE_URL=
KNOWLEDGE_TOPIC_NAMING_MODEL=

# Smart Topics incremental matching threshold
KNOWLEDGE_TOPIC_MATCH_THRESHOLD=0.85

# Tencent Cloud (for ASR)
TENCENT_SECRET_ID=your_tencent_secret_id
TENCENT_SECRET_KEY=your_tencent_secret_key

# Jina Reader (primary web content scraper for articles)
# Official site: https://jina.ai/reader/
# Free tier: 1000 requests/month, Paid: $20/month (10000 requests)
JINA_API_KEY=your_jina_api_key

# Supabase Storage (default bucket name)
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=user-files

# === 多云对象存储 ===
# 新写入后端：supabase | tencent-cos | volcengine-tos
STORAGE_PROVIDER=supabase

# 腾讯云 COS（生产首选）
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_REGION=ap-shanghai
TENCENT_COS_BUCKET=
TENCENT_COS_CUSTOM_DOMAIN=

# === 视频 AI 分析（Plan B） ===
# 音频/文本分析 provider：tingwu（首发唯一）
AUDIO_ANALYSIS_PROVIDER=tingwu
# 视觉分析 provider：qwen-vl | none
VISUAL_ANALYSIS_PROVIDER=qwen-vl

# 阿里通义听悟（ASR + 章节 + 摘要 + Q&A）
# 控制台：https://tingwu.aliyun.com
ALI_TINGWU_APPKEY=
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIBABA_CLOUD_REGION=cn-beijing

# 通义千问 + Qwen-VL（DashScope）
# 控制台：https://dashscope.console.aliyun.com
DASHSCOPE_API_KEY=
DASHSCOPE_TEXT_MODEL=qwen-plus
DASHSCOPE_VISION_MODEL=qwen-vl-max

# === 视频 worker（同进程后台任务） ===
# Phase 1 完成前保持 false；Phase 1 完成后改 true 启动后台 worker
VIDEO_WORKER_ENABLED=false
VIDEO_WORKER_INTERVAL_MS=10000
VIDEO_WORKER_BATCH_SIZE=5
