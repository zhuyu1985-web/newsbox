# =============================================================
# Self-hosted Supabase for NewsBox
# Usage: cp .env.example .env && edit
# =============================================================

# --- Secrets (MUST CHANGE) -----------------------------------
# 生成命令：openssl rand -base64 48 | tr -d '\n'
POSTGRES_PASSWORD=please-change-me-32-chars-min
JWT_SECRET=please-change-me-must-be-at-least-32-characters-long

# anon key 和 service_role key 用 JWT_SECRET 在
# https://supabase.com/docs/guides/self-hosting/docker#api-keys
# 在线生成（payload 见下方注释）
#
# anon payload:        {"role":"anon","iss":"supabase","iat":1700000000,"exp":9999999999}
# service_role payload:{"role":"service_role","iss":"supabase","iat":1700000000,"exp":9999999999}
ANON_KEY=paste-anon-jwt-here
SERVICE_ROLE_KEY=paste-service-role-jwt-here

# Studio 登录凭据
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=please-change-me

# --- URLs ----------------------------------------------------
# 本地开发：直接用 Kong 端口；生产环境改为反代域名
API_EXTERNAL_URL=http://127.0.0.1:18000
SUPABASE_PUBLIC_URL=http://127.0.0.1:18000
SITE_URL=http://localhost:3001
ADDITIONAL_REDIRECT_URLS=http://localhost:3001/**,http://127.0.0.1:3001/**

# --- 端口（newsbox 实例统一 +10000，避开常见 supabase 默认端口） ---
KONG_HTTP_PORT=18000
KONG_HTTPS_PORT=18443
# Postgres 仅监听 127.0.0.1；外网用 SSH tunnel
POSTGRES_PORT=127.0.0.1:15432

# --- SMTP（邮箱验证/密码重置） --------------------------------
SMTP_ADMIN_EMAIL=admin@your-domain.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxx
SMTP_SENDER_NAME=NewsBox

# Email 模板路径（GoTrue 默认即可）
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

# --- Auth 行为 ------------------------------------------------
# 内网离线部署（无 SMTP）→ 设为 true，注册立刻可登录
# 有内部邮件网关 / 外部 SMTP → 设为 false，保留邮箱验证
ENABLE_EMAIL_AUTOCONFIRM=true

# 公开注册开关。内网建议关闭，只用 admin 脚本邀请用户：
#   npx tsx scripts/admin/invite-user.ts <email>
GOTRUE_DISABLE_SIGNUP=false

# 最小密码长度
GOTRUE_PASSWORD_MIN_LENGTH=8

# --- OAuth Google --------------------------------------------
GOTRUE_EXTERNAL_GOOGLE_ENABLED=true
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
GOTRUE_EXTERNAL_GOOGLE_SECRET=

# --- OAuth GitHub --------------------------------------------
GOTRUE_EXTERNAL_GITHUB_ENABLED=true
GOTRUE_EXTERNAL_GITHUB_CLIENT_ID=
GOTRUE_EXTERNAL_GITHUB_SECRET=

# --- Studio 默认显示 -----------------------------------------
STUDIO_DEFAULT_ORGANIZATION=NewsBox
STUDIO_DEFAULT_PROJECT=NewsBox

# --- Storage 图片转换 -----------------------------------------
IMGPROXY_ENABLE_WEBP_DETECTION=true

# --- Edge Functions ------------------------------------------
# 项目内 cron 端点不需要 JWT，由 KNOWLEDGE_CRON_SECRET 自验
FUNCTIONS_VERIFY_JWT=false

# --- PostgREST 暴露的 schema --------------------------------
PGRST_DB_SCHEMAS=public,storage,graphql_public

# --- 系统 ----------------------------------------------------
TZ=Asia/Shanghai

# --- 日志聚合（可选，关闭可在 docker-compose.yml 注释 analytics） ---
LOGFLARE_API_KEY=disabled
