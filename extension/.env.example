# Copy to .env and fill in your values
#
# Supabase URL —— 决定扩展构建时注入的 host_permissions：
#   - Cloud:   https://<ref>.supabase.co  → 自动用 https://*.supabase.co/*
#   - 自托管:  https://supabase.your-intranet.local 或 http://supabase.lan
#              → 自动用 ${protocol}//${hostname}/*
#   修改后必须重新 `npm run build` 让扩展生效
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-key
VITE_NEWSBOX_API_URL=http://localhost:3000
